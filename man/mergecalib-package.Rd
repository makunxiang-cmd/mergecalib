\docType{package}
\title{Deterministic Cell Merging for Interval Calibration Targets}
\description{
Constructs deterministic within-province demographic-cell merging plans under
provincial and national subgroup grade-proportion interval constraints. Every
selected final cluster is required to have positive sample size.
}
\details{
The package generates candidate merged cells, formulates a set-partitioning
mixed-integer linear program, searches for the minimum target-range relaxation
when needed, and lexicographically minimizes statistical distortion.
}
\author{Kunxiang Ma}
